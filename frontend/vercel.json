{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-tools-directory-production-3e93.up.railway.app/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/tools/:slug",
      "destination": "/tool.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}