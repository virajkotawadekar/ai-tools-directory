{
  "rewrites": [
    {
      "source": "/login",
      "destination": "/frontend/login.html"
    },
    {
      "source": "/tools/:slug",
      "destination": "/frontend/tool.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}